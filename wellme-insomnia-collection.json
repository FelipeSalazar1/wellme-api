    },
    {
      "_id": "req_flow_6",
      "_type": "request",
      "parentId": "fld_flow",
      "name": "6. Submeter quiz (100%)",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/quizzes/qz-hidr-001/submit",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": \"{{ _.user_id }}\",\n  \"answers\": {\n    \"qq-h001-1\": \"C\",\n    \"qq-h001-2\": \"C\",\n    \"qq-h001-3\": \"B\",\n    \"qq-h001-4\": \"C\",\n    \"qq-h001-5\": \"C\"\n  }\n}"
      },
      "headers": [
