    {
      "_id": "fld_auth",
      "_type": "request_group",
      "parentId": "wrk_wellme",
      "name": "Auth"
    },
    {
      "_id": "req_login",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Login (obter JWT — admin/123456)",
      "method": "POST",
      "url": "{{ _.base_url }}/auth/login",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "description": "Retorna token JWT. Copie o valor de 'token' e cole na variável de ambiente 'jwt'."
    },

    {
      "_id": "fld_users",
      "_type": "request_group",
      "parentId": "wrk_wellme",
      "name": "Usuários"
    },
    {
      "_id": "req_list_users",
      "_type": "request",
      "parentId": "fld_users",
      "name": "Listar todos os usuários",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/users",
      "description": "Público — lista todos os usuários cadastrados."
    },
    {
      "_id": "req_get_user",
      "_type": "request",
      "parentId": "fld_users",
      "name": "Buscar usuário por ID",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/users/{{ _.user_id }}",
      "description": "Público — preencha user_id no ambiente."
    },
    {
      "_id": "req_register_user",
      "_type": "request",
      "parentId": "fld_users",
      "name": "Cadastrar usuário (público)",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/users/register",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Maria Souza\",\n  \"email\": \"maria@wellme.com\",\n  \"password\": \"senha1234\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "description": "Público. Valida: e-mail único, senha mínimo 8 caracteres. Retorna 201 com o usuário criado. Copie o ID retornado para a variável 'user_id'."
    },
    {
      "_id": "req_update_user",
      "_type": "request",
      "parentId": "fld_users",
      "name": "Atualizar perfil do usuário",
      "method": "PUT",
      "url": "{{ _.base_url }}/api/v1/users/{{ _.user_id }}",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Maria Souza Atualizada\",\n  \"photoUrl\": \"https://exemplo.com/foto.jpg\",\n  \"dailyWaterGoalMl\": 2500,\n  \"notificationsEnabled\": true\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.jwt }}" }
      ],
      "description": "Requer JWT. Atualiza nome, foto, meta diária de água e configuração de notificações."
    },
    {
      "_id": "req_delete_user",
      "_type": "request",
      "parentId": "fld_users",
      "name": "Remover usuário",
      "method": "DELETE",
      "url": "{{ _.base_url }}/api/v1/users/{{ _.user_id }}",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ _.jwt }}" }],
      "description": "Requer JWT. Retorna 204 No Content."
    },
    {
      "_id": "req_dashboard",
      "_type": "request",
      "parentId": "fld_users",
      "name": "Dashboard do usuário",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/users/{{ _.user_id }}/dashboard",
      "description": "Público. Exibe: XP, nível, XP para próximo nível, fases concluídas, fases em andamento, badges conquistados, trilhas iniciadas, água consumida hoje vs meta."
    },

    {
      "_id": "fld_trails",
      "_type": "request_group",
      "parentId": "wrk_wellme",
      "name": "Trilhas & Fases"
    },
    {
      "_id": "req_list_trails",
      "_type": "request",
      "parentId": "fld_trails",
      "name": "Listar trilhas ativas",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/trails",
      "description": "Público. Retorna as 5 trilhas do seed: Hidratação, Alimentação, Sono, Saúde Mental, Exercícios."
    },
    {
      "_id": "req_list_all_trails",
      "_type": "request",
      "parentId": "fld_trails",
      "name": "Listar todas as trilhas (incl. inativas)",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/trails/all",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ _.jwt }}" }],
      "description": "Requer JWT. Admin — inclui trilhas desativadas."
    },
    {
      "_id": "req_get_trail",
      "_type": "request",
      "parentId": "fld_trails",
      "name": "Buscar trilha por ID (Hidratação)",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/trails/{{ _.trail_id_hidr }}",
      "description": "Público. Usa a trilha de Hidratação do seed."
    },
    {
      "_id": "req_create_trail",
      "_type": "request",
      "parentId": "fld_trails",
      "name": "Criar trilha",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/trails",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"title\": \"Prevenção de Doenças\",\n  \"description\": \"Aprenda a prevenir as doenças mais comuns com hábitos simples.\",\n  \"category\": \"PREVENCAO\",\n  \"orderIndex\": 6\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.jwt }}" }
      ],
      "description": "Requer JWT. Categorias válidas: HIDRATACAO | ALIMENTACAO | SONO | SAUDE_MENTAL | EXERCICIO | PREVENCAO"
    },
    {
      "_id": "req_update_trail",
      "_type": "request",
      "parentId": "fld_trails",
      "name": "Atualizar trilha",
      "method": "PUT",
      "url": "{{ _.base_url }}/api/v1/trails/{{ _.trail_id_hidr }}",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"title\": \"Hidratação Saudável — Atualizada\",\n  \"description\": \"Conteúdo atualizado sobre hidratação.\",\n  \"category\": \"HIDRATACAO\",\n  \"orderIndex\": 1\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.jwt }}" }
      ]
    },
    {
      "_id": "req_deactivate_trail",
      "_type": "request",
      "parentId": "fld_trails",
      "name": "Desativar trilha (exclusão lógica)",
      "method": "DELETE",
      "url": "{{ _.base_url }}/api/v1/trails/{{ _.trail_id_exer }}",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ _.jwt }}" }],
      "description": "Requer JWT. Marca a trilha como inativa (active=false). Usa trilha de Exercícios."
    },
    {
      "_id": "req_list_phases",
      "_type": "request",
      "parentId": "fld_trails",
      "name": "Listar fases da trilha de Hidratação",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/trails/{{ _.trail_id_hidr }}/phases",
      "description": "Público. Retorna as 2 fases da trilha de Hidratação do seed."
    },
    {
      "_id": "req_get_phase",
      "_type": "request",
      "parentId": "fld_trails",
      "name": "Buscar fase por ID",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/trails/phases/{{ _.phase_id_hidr1 }}",
      "description": "Público. Retorna fase 'Por que se hidratar?' com conteúdo educativo completo."
    },
    {
      "_id": "req_create_phase",
      "_type": "request",
      "parentId": "fld_trails",
      "name": "Criar fase",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/trails/phases",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"trailId\": \"{{ _.trail_id_alim }}\",\n  \"title\": \"Desafio Diário de Alimentação\",\n  \"content\": \"Os desafios diários ajudam a criar hábitos alimentares saudáveis de forma gradual. Comece substituindo uma refeição processada por uma opção in natura.\",\n  \"xpReward\": 20,\n  \"orderIndex\": 2\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.jwt }}" }
      ],
      "description": "Requer JWT. Cria nova fase na trilha de Alimentação."
    },

    {
      "_id": "fld_quiz",
      "_type": "request_group",
      "parentId": "wrk_wellme",
      "name": "Quizzes"
    },
    {
      "_id": "req_get_quiz_by_phase",
      "_type": "request",
      "parentId": "fld_quiz",
      "name": "Buscar quiz da fase (sem gabaritos)",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/quizzes/phase/{{ _.phase_id_hidr1 }}",
      "description": "Público. Retorna o quiz com as 5 questões de hidratação. O campo correctOption NÃO é exposto."
    },
    {
      "_id": "req_get_quiz_by_id",
      "_type": "request",
      "parentId": "fld_quiz",
      "name": "Buscar quiz por ID",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/quizzes/{{ _.quiz_id_hidr1 }}",
      "description": "Público. Mesmo resultado do endpoint por fase."
    },
    {
      "_id": "req_submit_quiz_perfect",
      "_type": "request",
      "parentId": "fld_quiz",
      "name": "Submeter quiz — 5/5 corretas (score 100%)",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/quizzes/{{ _.quiz_id_hidr1 }}/submit",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": \"{{ _.user_id }}\",\n  \"answers\": {\n    \"qq-h001-1\": \"C\",\n    \"qq-h001-2\": \"C\",\n    \"qq-h001-3\": \"B\",\n    \"qq-h001-4\": \"C\",\n    \"qq-h001-5\": \"C\"\n  }\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.jwt }}" }
      ],
      "description": "Requer JWT. ATENÇÃO: inicie a fase antes (POST /progress/start). Score 100% → ganha 25 XP + badge Quiz Master. Resposta inclui: totalQuestions, correctAnswers, scorePercent, xpEarned, totalXp, currentLevel, feedback."
    },
    {
      "_id": "req_submit_quiz_partial",
      "_type": "request",
      "parentId": "fld_quiz",
      "name": "Submeter quiz — 3/5 corretas (score 60%)",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/quizzes/{{ _.quiz_id_hidr1 }}/submit",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": \"{{ _.user_id }}\",\n  \"answers\": {\n    \"qq-h001-1\": \"C\",\n    \"qq-h001-2\": \"A\",\n    \"qq-h001-3\": \"B\",\n    \"qq-h001-4\": \"A\",\n    \"qq-h001-5\": \"C\"\n  }\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.jwt }}" }
      ],
      "description": "Requer JWT. Score 60% → ganha 15 XP (25 × 0.6). Feedback: 'Bom esforço! Continue estudando.'"
    },

    {
      "_id": "fld_progress",
      "_type": "request_group",
      "parentId": "wrk_wellme",
      "name": "Progresso"
    },
    {
      "_id": "req_start_phase_hidr1",
      "_type": "request",
      "parentId": "fld_progress",
      "name": "Iniciar fase — Hidratação Fase 1",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/progress/start?userId={{ _.user_id }}&phaseId={{ _.phase_id_hidr1 }}",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ _.jwt }}" }],
      "description": "Requer JWT. Cria UserProgress com status IN_PROGRESS e concede 15 XP. Execute este ANTES de submeter o quiz."
    },
    {
      "_id": "req_start_phase_hidr2",
      "_type": "request",
      "parentId": "fld_progress",
      "name": "Iniciar fase — Hidratação Fase 2",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/progress/start?userId={{ _.user_id }}&phaseId={{ _.phase_id_hidr2 }}",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ _.jwt }}" }],
      "description": "Requer JWT. Inicia segunda fase da trilha de Hidratação."
    },
    {
      "_id": "req_start_phase_alim1",
      "_type": "request",
      "parentId": "fld_progress",
      "name": "Iniciar fase — Alimentação Fase 1",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/progress/start?userId={{ _.user_id }}&phaseId={{ _.phase_id_alim1 }}",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ _.jwt }}" }],
      "description": "Requer JWT. Inicia fase da trilha de Alimentação (trilha diferente — necessário para badge Explorador)."
    },
    {
      "_id": "req_get_user_progress",
      "_type": "request",
      "parentId": "fld_progress",
      "name": "Listar progresso do usuário",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/progress/user/{{ _.user_id }}",
      "description": "Público. Lista todo o progresso do usuário com status, score e XP ganho em cada fase."
    },
    {
      "_id": "req_get_phase_progress",
      "_type": "request",
      "parentId": "fld_progress",
      "name": "Progresso em fase específica",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/progress/user/{{ _.user_id }}/phase/{{ _.phase_id_hidr1 }}",
      "description": "Público. Verifica status de progresso do usuário na fase de Hidratação 1."
    },

