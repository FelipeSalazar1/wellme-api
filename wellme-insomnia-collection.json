        "trail_id_alim": "tr-alim-0002-0002-000000000002",
        "trail_id_sono": "tr-sono-0003-0003-000000000003",
        "trail_id_ment": "tr-ment-0004-0004-000000000004",
        "trail_id_exer": "tr-exer-0005-0005-000000000005",
        "phase_id_hidr1": "ph-hidr-001",
        "phase_id_hidr2": "ph-hidr-002",
        "phase_id_alim1": "ph-alim-001",
