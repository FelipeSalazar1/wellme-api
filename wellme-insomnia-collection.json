      "_id": "req_err_senha_curta",
      "_type": "request",
      "parentId": "fld_erros",
      "name": "400 — Senha muito curta",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/users/register",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Teste\",\n  \"email\": \"teste@wellme.com\",\n  \"password\": \"123\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "description": "Espera 400 Bad Request — Bean Validation: senha deve ter mínimo 8 caracteres."
    },
