        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Estudante FIAP\",\n  \"email\": \"estudante@fiap.com\",\n  \"password\": \"fiap2026!\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
