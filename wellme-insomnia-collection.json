      "_id": "req_err_user_nao_encontrado",
      "_type": "request",
      "parentId": "fld_erros",
      "name": "404 — Usuário não encontrado",
      "method": "GET",
      "url": "{{ _.base_url }}/api/v1/users/00000000-0000-0000-0000-000000000000",
      "description": "Espera 404 Not Found — ResourceNotFoundException."
