        "mimeType": "application/json",
        "text": "{\n  \"userId\": \"{{ _.user_id }}\",\n  \"answers\": {\n    \"qq-h001-1\": \"C\",\n    \"qq-h001-2\": \"C\",\n    \"qq-h001-3\": \"B\",\n    \"qq-h001-4\": \"C\",\n    \"qq-h001-5\": \"C\"\n  }\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.jwt }}" }
      ],
      "description": "Espera 404 Not Found — Fase não foi iniciada. Use POST /progress/start antes de submeter."
    },
    {
      "_id": "req_err_quiz_resubmissao",
      "_type": "request",
      "parentId": "fld_erros",
      "name": "409 — Resubmissão de quiz",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/quizzes/{{ _.quiz_id_hidr1 }}/submit",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": \"{{ _.user_id }}\",\n  \"answers\": {\n    \"qq-h001-1\": \"A\",\n    \"qq-h001-2\": \"A\",\n    \"qq-h001-3\": \"A\",\n    \"qq-h001-4\": \"A\",\n    \"qq-h001-5\": \"A\"\n  }\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.jwt }}" }
      ],
      "description": "Espera 409 Conflict — QuizAlreadySubmittedException. Execute após já ter submetido o quiz."
    },
    {
      "_id": "req_err_opcao_invalida",
      "_type": "request",
      "parentId": "fld_erros",
      "name": "400 — Opção de resposta inválida",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/quizzes/{{ _.quiz_id_hidr1 }}/submit",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"userId\": \"{{ _.user_id }}\",\n  \"answers\": {\n    \"qq-h001-1\": \"E\",\n    \"qq-h001-2\": \"C\",\n    \"qq-h001-3\": \"B\",\n    \"qq-h001-4\": \"C\",\n    \"qq-h001-5\": \"C\"\n  }\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.jwt }}" }
      ],
      "description": "Espera 400 Bad Request — InvalidAnswerException: opção 'E' é inválida (aceita apenas A, B, C ou D)."
    },
    {
      "_id": "req_err_sem_jwt",
      "_type": "request",
      "parentId": "fld_erros",
      "name": "401 — Sem autenticação",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/trails",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"title\": \"Trilha sem auth\",\n  \"category\": \"PREVENCAO\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "description": "Espera 401 Unauthorized — nenhum header Authorization enviado."
    },
    {
      "_id": "req_err_agua_negativa",
      "_type": "request",
      "parentId": "fld_erros",
      "name": "400 — Quantidade de água inválida",
      "method": "POST",
      "url": "{{ _.base_url }}/api/v1/water/user/{{ _.user_id }}/log",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"amountMl\": 0\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.jwt }}" }
      ],
      "description": "Espera 400 Bad Request — Bean Validation: amountMl deve ser maior que zero."
    },

    {
      "_id": "fld_flow",
      "_type": "request_group",
      "parentId": "wrk_wellme",
      "name": "Fluxo Completo (passo a passo)"
    },
    {
      "_id": "req_flow_1",
      "_type": "request",
